	<!-- Zámek aplikace přes Face ID -->
	<key>NSFaceIDUsageDescription</key>
	<string>Face ID slouží k odemčení aplikace Jahoda.</string>

	<!-- Výběr zákazníka z kontaktů při zadávání objednávky -->
	<key>NSContactsUsageDescription</key>
	<string>Kontakty slouží k rychlému vyplnění jména a telefonu zákazníka při zadávání objednávky.</string>

	<!-- Diktování objednávky hlasem -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Mikrofon slouží k nadiktování objednávky (jméno, telefon, kdy a kolik) během telefonátu.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Rozpoznávání řeči převede nadiktovanou objednávku na text a předvyplní formulář.</string>

	<!-- Zjištění, zda je nainstalovaný Messenger (pro tlačítko Messenger u objednávky) -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>fb-messenger</string>
		<string>whatsapp</string>
	</array>

	<!-- URL schéma pro návrat z přihlášení Googlem.
	     Nahraďte hodnotu REVERSED_CLIENT_ID z vašeho GoogleService-Info.plist — viz SETUP.md, krok 5. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.613825691281-9ovs3qddk0l2leraek6eef7d2fd1bg1v</string>
			</array>
		</dict>
	</array>
