rules_version = '2';

// Přístup mají jen povolené rodinné účty: kolekce `allowedUsers` obsahuje
// dokumenty, jejichž ID je e-mail člena rodiny (malými písmeny),
// např. allowedUsers/jana.novakova@gmail.com. Obsah dokumentu může být
// libovolný, třeba { name: "Jana" }.
service cloud.firestore {
  match /databases/{database}/documents {

    function isFamilyMember() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email.lower()));
    }

    // Objednávky a číselník produktů — čtení i zápis jen pro rodinu.
    match /orders/{orderId} {
      allow read, write: if isFamilyMember();
    }

    match /products/{productId} {
      allow read, write: if isFamilyMember();
    }

    // Seznam povolených účtů: rodina ho může číst (a spravovat),
    // úprava jde udělat i ručně ve Firebase Console.
    match /allowedUsers/{email} {
      allow read, write: if isFamilyMember();
    }
  }
}
